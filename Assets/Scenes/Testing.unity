MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1679391703}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d0d0911115b18e14981c6430f359de37, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PhoneEventController
  dayNightCycle: {fileID: 1592565946}
  phoneRingingAudio: {fileID: 0}
  phonePromptUI: {fileID: 432833836}
  parentConversation:
  - speakerName: Dad
    speakerPortrait: {fileID: 1684810904, guid: 6624f76164a3b3a4db520ff3367a7bd6, type: 3}
    dialogueText: Son, are you there ? Have you eaten anything today?
  - speakerName: Player
    speakerPortrait: {fileID: 21300000, guid: 0f1b1be1eb7ae2d42a801136b59cc444, type: 3}
    dialogueText: I'm here, Dad. Don't worry about me. I ate already, and work is
      going okay.
  - speakerName: Dad
    speakerPortrait: {fileID: 1684810904, guid: 6624f76164a3b3a4db520ff3367a7bd6, type: 3}
    dialogueText: You always say that so we won't worry. But I know you're working
      hard far from home. Your mother and I are proud of you.
  - speakerName: Player
    speakerPortrait: {fileID: 21300000, guid: 0f1b1be1eb7ae2d42a801136b59cc444, type: 3}
    dialogueText: I miss you both every day. I'm doing this so our family can have
      a better life. Please take care of your health.
  - speakerName: Dad
    speakerPortrait: {fileID: 1684810904, guid: 6624f76164a3b3a4db520ff3367a7bd6, type: 3}
    dialogueText: We will be okay. Just promise me you will take care of yourself
      tooBy the way mom wants to speak to you.
  - speakerName: Mom
    speakerPortrait: {fileID: 0}
    dialogueText: Hey honey, are you home? Have you been eating properly ?
  - speakerName: Player
    speakerPortrait: {fileID: 21300000, guid: 0f1b1be1eb7ae2d42a801136b59cc444, type: 3}
    dialogueText: Yes, Mom, I can hear you. I'm doing fine. I'm selling noodles tonight.
      I will try to get home as soon as I can but now I got to go love you mom.
  timeToRing: 19
  shakeAmount: 0.015
  shakeSpeed: 30
  outlineColor: {r: 1, g: 0.9, b: 0, a: 1}
  outlineIntensity: 1.06
  interactDistance: 6.78
